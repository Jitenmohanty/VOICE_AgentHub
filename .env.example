# ── Voxie environment ────────────────────────────────────────────────────────
# Copy to .env.local and fill in. Only the first three sections are required
# to boot; every provider below is Stripe-style gated — unset = that feature
# is silently disabled, nothing else breaks.

# ── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=                    # Neon Postgres connection string (pgvector enabled)

# ── Auth (required) ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=                 # openssl rand -hex 32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=                # Google OAuth (login + calendar booking reuse this app)
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI (required) ────────────────────────────────────────────────────────────
GOOGLE_GEMINI_API_KEY=           # Gemini Live voice + embeddings + WhatsApp text agent
ANTHROPIC_API_KEY=               # Claude post-call analysis, lead scoring, digests, evals

# ── Internal server-to-server (required — fails closed) ─────────────────────
INTERNAL_API_SECRET=             # openssl rand -hex 32

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=                  # Lead notifications, digests, quota + overage invoices
# Dev-only Gmail fallback (delivers to any recipient without a Resend domain):
GMAIL_SENDER=
GMAIL_APP_PASSWORD=

# ── Rate limiting (Upstash Redis — optional in dev) ──────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Background jobs (Inngest — optional in dev, falls back to direct HTTP) ───
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Billing: Stripe (international, USD) ─────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── Billing: Razorpay (India, INR) — also powers UPI links + overage invoices ─
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=         # webhook must subscribe to subscription.* + payment.failed + payment_link.paid
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=

# ── WhatsApp channel (Items 4 + 5) ───────────────────────────────────────────
WHATSAPP_BSP_PROVIDER=           # gupshup | twilio
WHATSAPP_BSP_API_KEY=            # Gupshup API key
WHATSAPP_BSP_SOURCE_NUMBER=      # digits with country code, no +
WHATSAPP_BSP_APP_NAME=
TWILIO_ACCOUNT_SID=              # Twilio alternative
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=            # E.164, e.g. +14155238886
WHATSAPP_INBOUND_TOKEN=          # openssl rand -hex 32; BSP webhook URL = /api/whatsapp/inbound?token=...

# ── Integration secrets at rest (Item 9 CRM + Item 7 calendar tokens) ────────
SECRETS_ENCRYPTION_KEY=          # openssl rand -hex 32 (AES-256-GCM)

# ── Call recording storage (Item 12 — Cloudflare R2, private bucket) ─────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Observability (optional) ─────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=agenthub
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
