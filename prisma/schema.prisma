generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ── Auth Models ───────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String     @default("BUSINESS_OWNER") // BUSINESS_OWNER | ADMIN
  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
  memberships   BusinessMember[]
  sentInvites   BusinessInvite[] @relation("InvitedBy")
  agentSessions AgentSession[] // legacy, kept for migration
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ── Multi-Tenant Models ───────────────────────

model Business {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String   @unique
  industry    String   // template id: hotel, medical, restaurant, interview, legal
  description String?
  logoUrl     String?
  website     String?
  phone       String?
  address     String?
  // Where lead-capture emails are sent. Falls back to owner.email at delivery time.
  notificationEmail String?

  // WhatsApp outbound confirmations (Item 4). Off by default; requires the
  // platform-level WHATSAPP_BSP_* env to be configured too (Stripe-style gating).
  whatsappEnabled    Boolean @default(false)
  // Optional per-business sender override; platform source number used if null.
  whatsappFromNumber String?

  // CRM push (Item 9). crmSecretEncrypted holds the provider credentials as an
  // AES-256-GCM blob (src/lib/crypto.ts) — NEVER return it from an API route.
  crmProvider        String? // zoho (leadsquared/kylas planned)
  crmConfig          Json?   // non-secret config: { region?, fieldMapping? }
  crmSecretEncrypted String? @db.Text
  // Optional outbound webhook for leads (Slack/HubSpot/Zapier/etc).
  // Signed with HMAC-SHA256 using webhookSecret in X-Voxie-Signature.
  webhookUrl    String?
  webhookSecret String?
  // Per-business email preferences. Missing key = default ON.
  // Shape: { leadCapture?: bool, quotaWarning?: bool }
  notificationPrefs Json?
  isActive    Boolean  @default(true)
  agents      Agent[]
  subscription Subscription?
  webhookDeliveries WebhookDelivery[]
  members     BusinessMember[]
  invites     BusinessInvite[]
  whatsappConversations WhatsAppConversation[]
  integrations Integration[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

/// Team membership. Owner-equivalent access for v1 — every member can do
/// anything the owner can EXCEPT being removed by another member (only the
/// owner can remove members; the owner row is the implicit anchor via
/// Business.ownerId, not stored here).
model BusinessMember {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   @default("member") // member | (future: viewer, billing-only, etc.)
  invitedBy  String?
  joinedAt   DateTime @default(now())

  @@unique([businessId, userId])
  @@index([userId])
}

/// Pending invitation. Single-use token; expires after 7 days.
model BusinessInvite {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  email       String
  role        String    @default("member")
  token       String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String?
  invitedBy   User?     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([businessId, acceptedAt])
  @@index([email])
}

/// One row per outbound webhook attempt made by `deliverLead`. Used by the
/// settings page to show owners whether their endpoint is actually receiving
/// leads — without this, a misconfigured URL fails silently.
model WebhookDelivery {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sessionId    String?  // AgentSession that triggered the call (no FK — sessions get hard-deleted)
  url          String
  event        String   @default("lead.captured")
  statusCode   Int?     // null if the request never completed (DNS, timeout, network)
  latencyMs    Int?
  errorMessage String?  // populated when statusCode is null
  ok           Boolean  @default(false)
  attempt      Int      @default(1)
  createdAt    DateTime @default(now())

  @@index([businessId, createdAt])
}

// ── Billing ──────────────────────────────────────

model BillingPlan {
  // Stable string IDs ("free" | "starter" | "pro") so app code can reference
  // them without an extra lookup. Provider IDs change; these don't.
  id              String   @id
  name            String
  monthlyMinutes  Int      // included voice minutes per billing period
  maxAgents       Int      // hard cap on agents per business
  // Pricing in two denominations: USD cents for Stripe and INR paise for
  // Razorpay. Both are nullable; a plan may be offered through one provider
  // only, or both. Free tier sets both to 0.
  priceCents      Int      // monthly price in USD cents (0 for free)
  priceInrPaise   Int?     // monthly price in INR paise (1 INR = 100 paise)
  stripePriceId   String?  // Stripe Price ID (null for free or India-only)
  razorpayPlanId  String?  // Razorpay Plan ID (null for free or US-only)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  subscriptions   Subscription[]
  createdAt       DateTime @default(now())
}

model Subscription {
  id                    String      @id @default(cuid())
  businessId            String      @unique
  business              Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  planId                String
  plan                  BillingPlan @relation(fields: [planId], references: [id])
  // active | trialing | past_due | canceled | incomplete
  status                String      @default("active")
  // Which payment processor the active subscription is on. null = free tier
  // or no active paid sub. "stripe" or "razorpay".
  paymentProvider       String?
  // Stripe IDs (set when paymentProvider = "stripe")
  stripeCustomerId      String?
  stripeSubscriptionId  String?     @unique
  // Razorpay IDs (set when paymentProvider = "razorpay")
  razorpayCustomerId    String?
  razorpaySubscriptionId String?    @unique
  // Period window — month-to-date usage is computed against currentPeriodStart.
  currentPeriodStart    DateTime    @default(now())
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean     @default(false)
  // Idempotency for quota threshold emails: "none" | "80" | "95" | "100"
  lastQuotaNotice       String      @default("none")
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([planId])
  @@index([stripeCustomerId])
  @@index([razorpayCustomerId])
  @@index([currentPeriodEnd])
}

model Agent {
  id            String          @id @default(cuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  templateType  String          // hotel, medical, restaurant, interview, legal
  name          String
  description   String?
  isActive      Boolean         @default(true)

  // Prompt customization
  systemPrompt  String?         @db.Text
  greeting      String?
  personality   String?
  rules         String?         @db.Text

  // Template-specific config (hotelName, cuisineType, etc.)
  config        Json            @default("{}")

  // Tool & voice settings
  enabledTools  String[]        @default([])
  voiceName     String?
  language      String          @default("en")

  // Relations
  knowledgeItems  KnowledgeItem[]
  businessData    BusinessData[]
  agentSessions   AgentSession[]
  knowledgeGaps   KnowledgeGap[]
  whatsappConversations WhatsAppConversation[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([businessId])
}

// ── Third-party integrations (Item 7: Google Calendar; more later) ──────
// secretEncrypted is an AES-256-GCM blob (src/lib/crypto.ts) holding the
// provider's long-lived credential (e.g. { refreshToken }). NEVER return it
// from an API route.

model Integration {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  provider        String   // google-calendar
  secretEncrypted String   @db.Text
  accountEmail    String?  // which Google account is connected (display only)
  status          String   @default("active") // active | needs_reauth
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([businessId, provider])
}

// ── WhatsApp inbound text agent (Item 5) ──────
// One row per (business, caller number). The same agent brain that answers
// voice calls replies here over Gemini text mode. When captureLead fires,
// an AgentSession is created and the normal post-call pipeline (Claude
// scoring, lead email, webhook, WhatsApp confirmation) takes over.

model WhatsAppConversation {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  agentId       String
  agent         Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  fromNumber    String   // caller's WhatsApp number — digits with country code
  // [{ role: "user" | "agent", text, at }] — capped to the most recent 60
  messages      Json     @default("[]")
  capturedLead  Json?
  // AgentSession created when a lead was captured in this thread
  sessionId     String?
  lastInboundAt DateTime @default(now())
  // While set and in the future, the AI does not reply — a human has taken over.
  humanTakeoverUntil DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([businessId, fromNumber])
  @@index([agentId, lastInboundAt])
}

// ── Knowledge Gap (Item 2 — gap detection) ────
// A caller asked something and the agent's searchKnowledge tool returned
// zero hits. Each row is a deduped "unanswered question" the owner can turn
// into a KnowledgeItem, or dismiss. Written fire-and-forget from the
// search-knowledge route; surfaced on the knowledge page + weekly digest.

model KnowledgeGap {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Normalized (lowercased, trimmed) query text for dedup; display uses this too.
  query       String
  // open | dismissed | resolved (resolved = owner added an answer from it)
  status      String   @default("open")
  // How many times callers asked this (increments on dedup hit).
  hits        Int      @default(1)
  lastAskedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([agentId, status])
}

model KnowledgeItem {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  category   String   // faq, policy, menu, service, general
  sourceType String   @default("TEXT") // TEXT, FAQ, DOCUMENT, URL
  embedding  Unsupported("vector(768)")? // Gemini embedding dimension
  // pending | ready | failed — visibility for async embedding generation
  embeddingStatus String @default("pending")
  embeddingError  String? @db.Text
  metadata   Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([agentId])
  @@index([category])
  @@index([embeddingStatus])
}

model BusinessData {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dataType  String   // rooms, menu_items, services, doctors, pricing
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, dataType])
  @@index([agentId])
}

// ── Session Model (anonymous callers) ─────────

model AgentSession {
  id             String   @id @default(cuid())
  agentId        String?
  agent          Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Legacy fields (kept for migration, will be removed)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentType      String?

  // Anonymous caller info
  callerName     String?
  callerPhone    String?
  callerEmail    String?

  // Session data
  title          String?
  transcript     Json?
  duration       Int?
  status         String   @default("active") // active, completed, cancelled

  // Bearer token issued at creation, required on anonymous PATCH so callers
  // can't forge or overwrite each other's transcripts using only the cuid.
  updateToken    String?

  // Post-call intelligence (Claude)
  summary        String?  @db.Text
  sentiment      String?  // positive, neutral, negative, mixed
  sentimentScore Float?
  actionItems    Json?
  topics         String[] @default([])
  escalated      Boolean  @default(false)

  // Customer rating
  rating         Int?
  feedback       String?

  // Structured lead captured by the agent's captureLead tool during the call.
  // Shape: { name?, phone?, email?, intent, urgency?, notes?, capturedAt }
  capturedLead   Json?
  // Set when the lead notification email has been delivered to the business owner.
  // Used as an idempotency guard so retried Inngest runs don't double-send.
  leadDeliveredAt DateTime?
  // Owner-managed lead state.
  // new | contacted | qualified | won | lost | archived
  leadStatus     String   @default("new")

  // AI lead scoring (Claude post-call). All nullable — additive, older
  // sessions simply have no score until re-analyzed.
  leadScore      Int?     // 0-100 lead quality estimate
  intentCategory String?  // booking | pricing | support | complaint | information | spam | other
  suggestedReply String?  @db.Text // one-tap follow-up draft for the owner

  // WhatsApp confirmation to the caller (Item 4). Idempotency mirror of
  // leadDeliveredAt for the WhatsApp channel.
  whatsappDeliveredAt DateTime?
  whatsappMessageId   String?
  whatsappStatus      String?   // sent | failed

  // CRM push (Item 9). crmPushedAt doubles as the idempotency marker.
  crmPushedAt  DateTime?
  crmRecordId  String?
  crmError     String?   @db.Text

  // Real calendar booking (Item 7). Stamped by /confirm-appointment when the
  // agent books an actual Google Calendar event mid-call.
  bookedAppointmentAt DateTime?
  bookedSlot          String?   // ISO start time of the booked slot
  bookedEventId       String?   // Google Calendar event id

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agentId])
  @@index([createdAt])
  @@index([status])
  @@index([leadStatus])
}
