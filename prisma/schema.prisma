generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ── Auth Models ───────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String     @default("BUSINESS_OWNER") // BUSINESS_OWNER | ADMIN
  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
  agentSessions AgentSession[] // legacy, kept for migration
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Multi-Tenant Models ───────────────────────

model Business {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String   @unique
  industry    String   // template id: hotel, medical, restaurant, interview, legal
  description String?
  logoUrl     String?
  website     String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  agents      Agent[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
}

model Agent {
  id            String          @id @default(cuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  templateType  String          // hotel, medical, restaurant, interview, legal
  name          String
  description   String?
  isActive      Boolean         @default(true)

  // Prompt customization
  systemPrompt  String?         @db.Text
  greeting      String?
  personality   String?
  rules         String?         @db.Text

  // Template-specific config (hotelName, cuisineType, etc.)
  config        Json            @default("{}")

  // Tool & voice settings
  enabledTools  String[]        @default([])
  voiceName     String?
  language      String          @default("en")

  // Relations
  knowledgeItems  KnowledgeItem[]
  businessData    BusinessData[]
  agentSessions   AgentSession[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([businessId])
}

model KnowledgeItem {
  id         String   @id @default(cuid())
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title      String
  content    String   @db.Text
  category   String   // faq, policy, menu, service, general
  sourceType String   @default("TEXT") // TEXT, FAQ, DOCUMENT, URL
  embedding  Unsupported("vector(768)")? // Gemini embedding dimension
  metadata   Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([agentId])
  @@index([category])
}

model BusinessData {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  dataType  String   // rooms, menu_items, services, doctors, pricing
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([agentId, dataType])
  @@index([agentId])
}

// ── Session Model (anonymous callers) ─────────

model AgentSession {
  id             String   @id @default(cuid())
  agentId        String?
  agent          Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Legacy fields (kept for migration, will be removed)
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentType      String?

  // Anonymous caller info
  callerName     String?
  callerPhone    String?
  callerEmail    String?

  // Session data
  title          String?
  transcript     Json?
  duration       Int?
  status         String   @default("active") // active, completed, cancelled

  // Post-call intelligence (Claude)
  summary        String?  @db.Text
  sentiment      String?  // positive, neutral, negative, mixed
  sentimentScore Float?
  actionItems    Json?
  topics         String[] @default([])
  escalated      Boolean  @default(false)

  // Customer rating
  rating         Int?
  feedback       String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agentId])
  @@index([createdAt])
  @@index([status])
}
